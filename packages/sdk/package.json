{
  "name": "@afriex/sdk",
  "version": "1.2.0",
  "description": "Official TypeScript SDK for the Afriex Business API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://afriex-sdk-docs.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/codewithveek/afriex_sdk.git",
    "directory": "packages/sdk"
  },
  "author": "Victory Lucky <luckyvictory54@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@afriex/core": "workspace:*",
    "@afriex/customers": "workspace:*",
    "@afriex/transactions": "workspace:*",
    "@afriex/payment-methods": "workspace:*",
    "@afriex/balance": "workspace:*",
    "@afriex/rates": "workspace:*",
    "@afriex/webhooks": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "afriex",
    "sdk",
    "api",
    "money-transfer",
    "payments",
    "fintech",
    "typescript"
  ],
  "license": "MIT"
}
